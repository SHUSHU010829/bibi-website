# bibi-website environment variables
# 部署於 Zeabur 時，請在專案 Settings → Variables 設定相同的值。

# --- Discord OAuth2 (scope: identify) -----------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# https://<website>/api/auth/discord/callback
DISCORD_REDIRECT_URI=

# 主 guild ID（傳給 bot 的 session API；目前 confirm 頁也用來顯示）
PRIMARY_GUILD_ID=1174352637295067157

# 簽 Discord session cookie 用，建議 openssl rand -hex 32
DISCORD_SESSION_SECRET=

# --- bot 介接（W4 之後啟用，本階段可留空，create / status 會走 stub） ---
BOT_API_BASE_URL=
DONATION_GRANT_SECRET=

# --- 共用 MongoDB（W5 之後啟用，本階段可留空） --------------------------
MONGODB_URI_READONLY=

# --- 實況主收款 ID（從付款 URL 拿） -------------------------------------
ECPAY_BROADCASTER_ID=DB653B5A8412C200A0997E7DDDCFF539
OPAY_BROADCASTER_ID=37AAD58C9C2DF7993500AB06A67A8F57

# --- HashKey / HashIV（廠商管理後台 → 系統介接設定；敏感資訊只填到 Zeabur） ---
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
OPAY_HASH_KEY=
OPAY_HASH_IV=

# --- 開發 / 測試用（正式環境務必為 0 或不設） --------------------------
# 1 = webhook 跳過 CheckMacValue 驗證（給初次串接時用，正式環境一律 0）
DONATION_WEBHOOK_ALLOW_INSECURE=0
