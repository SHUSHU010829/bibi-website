# bibi-website environment variables
# 部署於 Vercel 時，請在專案 Settings → Environment Variables 設定相同的值。

# --- Discord OAuth2 (scope: identify) -----------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# https://<website>/api/auth/discord/callback
DISCORD_REDIRECT_URI=

# 主 guild ID（傳給 bot 的 session API；目前 confirm 頁也用來顯示）
PRIMARY_GUILD_ID=1174352637295067157

# 簽 Discord session cookie 用，建議 openssl rand -hex 32
DISCORD_SESSION_SECRET=

# --- bot 介接（W2 之後啟用，本階段可留空，create / status 會走 stub） ---
BOT_API_BASE_URL=
DONATION_GRANT_SECRET=

# --- 共用 MongoDB（W2 之後啟用，本階段可留空） --------------------------
MONGODB_URI_READONLY=

# --- 金流 HashKey / HashIV（W3 之後啟用） -------------------------------
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
OPAY_MERCHANT_ID=
OPAY_HASH_KEY=
OPAY_HASH_IV=
